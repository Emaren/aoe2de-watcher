# Required only if you do not want the default production endpoint.
AOE2_API_BASE_URL=https://api-prodn.aoe2hdbets.com

# Optional: set custom replay folder path.
# AOE2_WATCH_DIR=/path/to/Age2HD/SaveGame

# Optional: override uploader identity value sent as x-user-uid.
# WATCHER_USER_UID=your-uid-here

# Optional manual fallback: one-click profile pairing normally saves this for you.
# AOE2_UPLOAD_API_KEY=replace-with-watcher-key
